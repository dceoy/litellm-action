{
  "name": "litellm-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action to run LiteLLM proxy server",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:post",
    "build:main": "ncc build src/main.ts -o dist/main --source-map --license licenses.txt",
    "build:post": "ncc build src/post.ts -o dist/post --source-map --license licenses.txt",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "all": "npm run format && npm run lint && npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dceoy/litellm-action.git"
  },
  "keywords": [
    "github-action",
    "litellm",
    "proxy",
    "llm"
  ],
  "license": "AGPL-3.0",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
