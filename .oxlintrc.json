{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": ["coverage/**", "dist/**", "lib/**", "node_modules/**"],
  "overrides": [
    {
      "files": ["src/__tests__/**/*.test.ts"],
      "env": {
        "jest": true
      }
    }
  ]
}
